[Desktop Entry]
Version=1.0
Type=Application
Name=FluoroSim
Comment=Launch the FluoroSim simulation window with the web control panel
# Goes through systemd so the sim is supervised: it auto-restarts if it
# crashes, and "restart" makes the button work whether it's stopped or wedged.
# Requires ~/.config/systemd/user/fluorosim.service (see README).
Exec=systemctl --user restart fluorosim.service
Icon=/home/benknapp95/fluoro_simulator/static/logosign_white.png
Path=/home/benknapp95/fluoro_simulator
Terminal=false
Categories=Education;Science;
StartupNotify=true
